# Supabase project credentials
# Copy this file to src/config/env.ts and fill in your values
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key-here
# SUPABASE_FUNCTIONS_URL=https://your-project.supabase.co/functions/v1

# Google Sign-In
# GOOGLE_IOS_CLIENT_ID=your-google-ios-client-id.apps.googleusercontent.com

# Edge Function secrets (set via: supabase secrets set KEY=value)
# ANTHROPIC_API_KEY=sk-ant-...
# SERVICE_ROLE_KEY=your-service-role-key (SUPABASE_ prefix not allowed by Supabase CLI)
